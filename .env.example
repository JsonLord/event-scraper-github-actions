# Jules API Configuration
# Required for automated coding sessions
# Add your key: JULES_API_KEY=your_jules_api_key_here
JULES_API_KEY=your_jules_api_key_here

# Optional: Additional agent keys for load balancing
JULES_API_KEY_2=optional_second_agent_key
JULES_API_KEY_3=optional_third_agent_key
JULES_API_KEY_4=optional_fourth_agent_key

# GitHub Configuration
# Required for repository operations and PR creation
GITHUB_TOKEN=your_github_personal_access_token_here

# CloakBrowser Configuration (Optional)
# For stealth browser scraping with anti-bot detection bypass
CLOAKBROWSER_LICENSE_KEY=optional_pro_license_key_for_latest_binary

# Proxy Configuration (Optional)
# Use residential proxies for better success rates
# CLOAKBROWSER_PROXY=http://user:pass@residential-proxy:port

# GeoIP Configuration (Optional)
# Auto-detect timezone/locale from proxy IP
# Requires: pip install cloakbrowser[geoip]
# CLOAKBROWSER_GEOIP_ENABLED=true

# Event Scraper Configuration
EVENT_PRICE_MAX=15
EVENT_DATE_RANGE_DAYS=14
EVENT_CATEGORIES=music,dance,social,networking

# Logging Configuration
LOG_LEVEL=INFO
